{
  "name": "cclive",
  "version": "0.1.0",
  "description": "Claude Code status line for live external data — stock tickers and sports league scores. Inspired by ccstatusline.",
  "type": "module",
  "bin": {
    "cclive": "src/index.js"
  },
  "main": "src/index.js",
  "files": [
    "src",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test test/"
  },
  "keywords": [
    "claude-code",
    "statusline",
    "ticker",
    "stocks",
    "sports",
    "epl",
    "nba",
    "nfl",
    "cricket"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yashjain/cclive"
  }
}
